{
  "name": "create-reactify-app",
  "version": "0.2.8",
  "description": "Scaffold Reactify projects — Fastify + React + Vite SSR",
  "type": "module",
  "bin": {
    "create-reactify-app": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./cli": {
      "import": "./dist/cli.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node_modules/.bin/tsdown --config build.config.ts",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "commander": "^15.0.0",
    "consola": "^3.4.2",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
