{
  "name": "create-reactify-app-monorepo",
  "scripts": {
    "dev": "bun run --filter create-reactify-app dev",
    "build": "bun run --cwd packages/cli build",
    "test": "bun run --cwd packages/cli test",
    "link": "bun run build && cd packages/cli && bun link",
    "typecheck": "tsc --noEmit",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "bun@1.3.13"
}
