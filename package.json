{
  "name": "create-reactify-app-monorepo",
  "scripts": {
    "dev": "bun run --filter create-reactify-app dev",
    "build": "cd packages/cli && bun run build",
    "test": "cd packages/cli && bun run test",
    "link": "bun run build && cd packages/cli && bun link",
    "typecheck": "tsc --noEmit",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "typescript": "^5.9.0"
  },
  "packageManager": "bun@1.3.13"
}
