{
  "name": "create-cyber-stack-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter create-cyber-stack dev",
    "build": "bun run --filter create-cyber-stack build",
    "link": "bun run build && cd packages/cli && bun link",
    "typecheck": "tsc --noEmit",
    "test": "bun run --filter '*' test"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  },
  "packageManager": "bun@1.3.13"
}
