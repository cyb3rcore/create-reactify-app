import { Suspense } from 'react'
import { Routes, Route } from 'react-router'
import { Router, AppRoute } from '$app/core.tsx'

interface RootProps {
  url: string
  routes: Array<{ path: string; component: React.ComponentType<any> }>
  head: any
  ctxHydration: any
  routeMap: Record<string, any>
}

export default function Root({ url, routes, head, ctxHydration, routeMap }: RootProps) {
  return (
    <Suspense>
      <Router location={url}>
        <Routes>
          {routes.map(({ path, component: Component }) => (
            <Route
              key={path}
              path={path}
              element={
                <AppRoute head={head} ctxHydration={ctxHydration} ctx={routeMap[path]}>
                  <Component />
                </AppRoute>
              }
            />
          ))}
        </Routes>
      </Router>
    </Suspense>
  )
}
